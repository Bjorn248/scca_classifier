{{ $name := .Name }}{{ $shortname := .ShortName }}{{ $chapterfillertext := .ChapterFillerText }}<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="Description" content="SCCA Solo Classifier Application - Street Modified Car Page">
    <title>SCCA Solo Classification Assistant</title>
    <script src="../common.js"></script>
    <link rel="stylesheet" href="../styles.css">
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.ico" type="image/x-icon">

    <div id="mySidebar" class="sidebar">
      <a href="javascript:void(0)" class="closebtn" onclick="closeNav()">×</a>
      <a id='{{ $shortname }}LandingPageMenu' href="#" onclick="resetQuestion('{{ $shortname }}LandingPage'); evalSessionStorage('{{ $shortname }}Car');">Overview</a>{{ range .SubChapters }}
      <a id='{{ toVarName $name}}{{ menuName .Name}}Menu' href="#" onclick="resetQuestion('{{ toVarName $name}}{{ menuName .Name }}'); evalSessionStorage('{{ $shortname }}Car');">{{ menuName .Name }}</a>{{ end }}
    </div>

  </head>

  <body onload="evalSessionStorage('{{ $shortname }}Car'); highlightAndFilterSM();">
    <!-- Modern Top Navigation Bar -->
    <nav class="top-nav">
      <div class="nav-left">
        <button class="hamburger-menu" onclick="openNav()" title="Open navigation menu">☰</button>
      </div>
      <div class="nav-center">
        <h1 class="nav-title">Street Modified Class Questionnaire</h1>
      </div>
      <div class="nav-right">
        <button class="nav-button" onclick="window.location.href = '/index.html';" title="Return to home page">
          🏠 Home
        </button>
        <button class="nav-button" onclick="resetState()" title="Clear question answers and selections">
          🔄 Clear
        </button>
      </div>
    </nav>
    <div id="{{ $shortname }}LandingPage" class="center question sansserif">
      <h2 id="{{ $shortname }}LandingPageQuestion">
        Street Modified (SM) Class Overview
      </h2>
      <div id="overviewBody" class="questionBody">
        <h3>
          Category Objective
        </h3>
        <p>
        Street Modified allows competitors to modify vehicles using advanced fabrication and
        tuning with specific limitations. Street Modified provides the allowances of the
        lower-prep categories with the addition of major modifications to the drivetrain,
        suspension, and body as well as sophisticated aerodynamic components
        </p>
        <p>
        The purpose of this category is to serve as a membership recruitment and retention tool
        by providing a natural competition outlet for auto enthusiasts using streetable sport
        sedans equipped with drivetrain and suspension modifications that are beyond those
        allowed in the Street Prepared category. Cars identical to the US-market counterpart
        except for comfort and convenience modifications as allowed per Section 13.2.A.
        See Sections 3.8 and 8.3.1 for documentation requirements
        </p>
        <h3>
          Category Values
        </h3>
        <p>
        Freedom to improve vehicles using a variety of methods including suspension geometry
        changes, extensive powertrain conversions and/or modifications
        </p>
        <h3>
          Core Modifications
        </h3>
        <ul class="list">
          <li>
            Powertrain swaps
          </li>
          <li>
            Open Engine Tuning
          </li>
          <li>
            Open Driver aid tuning (Traction control, ABS, Stability, Differential, etc.)
          </li>
          <li>
            Minimum weights based on displacement
          </li>
          <li>
            Limited interior removal
          </li>
          <li>
            SRS system removal
          </li>
          <li>
            Modifications may require cutting, drilling, or permanent alteration to the body,
            such as cutting fenders for tire clearance, and drilling trunks/hatches for
            spoiler/wing mounting
          </li>
          <li>
            DOT R-compound tires
          </li>
          <li>
            Front splitters and rear wings
          </li>
          <li>
            Custom suspension components
          </li>
          <li>
            Weight reduction (A/C removal, steering wheel airbag removal, lightweight body panels, etc.)
          </li>
        </ul>
        <h3>
          Inherited Modifications
        </h3>
        <ul class="list">
          <li>
            All Street, Street Touring®, and Street Prepared category modifications are authorized.
            Except as noted by these rules and the referenced rules, vehicles must be as originally
            delivered including all road-going components such as lights, wipers, interior, heater, etc
          </li>
          <li>
            Competitors may pick and choose between all Street, Street Touring®, Street Prepared,
            and Street Modified category allowances when preparing a Street Modified category car.
            Apparent conflicts between inherited rule sets from Section 16.1.A shall not prohibit
            any specific inherited allowance. Allowances inherited from Section 16.1.A may not
            incorporate Street Modified-specific allowances. Foreign spec parts may not be used to
            substitute for parts which are required to remain standard
          </li>
        </ul>
        <h3>
          Subclasses
        </h3>
        <p>
        Your subclass(es) should be highlighted
        </p>
        <ul>
          <li>
            <div id="ssmOverview">
              Super Street Modified (SSM) - 2-seat vehicles, FWD, RWD, and AWD
            </div>
          </li>
          <li>
            <div id="smOverview">
              Street Modified (SM) - 4-seat vehicles, FWD, RWD and AWD
            </div>
          </li>
          <li>
            <div id="smfOverview">
              Street Modified Front-Wheel Drive (SMF) - FWD vehicles only
            </div>
          </li>
        </ul>
      </div>
      </br>
      <button class="button yesButton" onclick="setState(['{{ $shortname }}LandingPage', '{{ $shortname }}CarAnsweredIndex'], [true, 0]); hideItem('{{ $shortname }}LandingPage'); evalSessionStorage('{{ $shortname }}Car'); window.scroll(0,0);">Continue</button>
    </div>

{{ $weightinfo := .WeightInformation }}{{ range $index, $subchapter := .SubChapters }}
    <div id="{{ toVarName $name}}{{ menuName $subchapter.Name }}" class="center question sansserif">
      <h2 id="{{ toVarName $name}}{{ menuName $subchapter.Name }}Question">
        Does your car meet the requirements below?
      </h2>
      <div id="{{ toVarName $name}}Body" class="questionBody">
        <h3>
          {{ subChapterText $subchapter.Reader $chapterfillertext }}
          {{if stringEqual $subchapter.Name "Minimum Weights"}}</br>{{$weightinfo}}{{ end }}
        </h3>
        {{if stringEqual $subchapter.Name "Minimum Weights"}}
        <div id="smWeightCalculator" class="weightCalc">
          <h3 class="weightCalcTitle">Minimum Weight Calculator</h3>
          <p class="weightCalcNote">
            Estimates the minimum competition weight (without driver) from the Appendix A
            formulas above. This is a planning aid &mdash; always verify against the current rulebook.
          </p>
          <fieldset>
            <p>
              <label for="smwcSubclass">Subclass:</label>
              <select id="smwcSubclass" class="select-css" onchange="smwcUpdateUI(); smwcCalculate();">
                <option value="SSM">Super Street Modified (SSM)</option>
                <option value="SM" selected>Street Modified (SM)</option>
                <option value="SMF">Street Modified FWD (SMF)</option>
              </select>
            </p>
            <p id="smwcDriveRow">
              <label for="smwcDrive">Drive type:</label>
              <select id="smwcDrive" class="select-css" onchange="smwcSyncRows(); smwcCalculate();">
                <option value="FWD">FWD</option>
                <option value="RWD" selected>RWD</option>
                <option value="AWD">AWD</option>
              </select>
            </p>
            <p>
              <label for="smwcDisp">Engine displacement (liters):</label>
              <input type="number" id="smwcDisp" min="0" step="0.1" value="2.0" oninput="smwcCalculate();">
            </p>
            <p id="smwcFiRow">
              <label for="smwcFi">Supercharged / Turbocharged:</label>
              <input type="checkbox" id="smwcFi" onchange="smwcCalculate();">
            </p>
            <p id="smwcTireRow">
              <label for="smwcTire">Tire width 275 mm or less:</label>
              <input type="checkbox" id="smwcTire" onchange="smwcCalculate();">
            </p>
            <p id="smwcSolidRow">
              <label for="smwcSolid">Solid axle RWD:</label>
              <input type="checkbox" id="smwcSolid" onchange="smwcCalculate();">
            </p>
          </fieldset>
          <p class="weightCalcResult">Minimum weight: <span id="smwcResult">&mdash;</span></p>
        </div>
        <script>
          (function() {
            var SMWC = {
              SSM: {base: {FWD: 1350, RWD: 1600, AWD: 1600}, perL: {FWD: 125, RWD: 200, AWD: 300}, fiAdd: 1.4, tire: true, solid: false, cap: 2900, drives: ['FWD', 'RWD', 'AWD']},
              SM: {base: {FWD: 1550, RWD: 1800, AWD: 1800}, perL: {FWD: 125, RWD: 200, AWD: 300}, fiAdd: 1.4, tire: true, solid: true, cap: 3100, drives: ['FWD', 'RWD', 'AWD']},
              SMF: {base: {FWD: 1750}, perL: {FWD: 125}, fiAdd: 1.0, tire: false, solid: false, cap: 3100, drives: ['FWD']}
            };
            function el(id) {
              return document.getElementById(id);
            }
            window.smwcSyncRows = function() {
              var cfg = SMWC[el('smwcSubclass').value];
              var drive = el('smwcDrive').value;
              el('smwcDriveRow').style.display = cfg.drives.length > 1 ? '' : 'none';
              el('smwcTireRow').style.display = cfg.tire ? '' : 'none';
              el('smwcSolidRow').style.display = (cfg.solid && drive === 'RWD') ? '' : 'none';
            };
            window.smwcUpdateUI = function() {
              var cfg = SMWC[el('smwcSubclass').value];
              var drive = el('smwcDrive');
              var current = drive.value;
              drive.innerHTML = '';
              cfg.drives.forEach(function(d) {
                var o = document.createElement('option');
                o.value = d;
                o.textContent = d;
                drive.appendChild(o);
              });
              drive.value = cfg.drives.indexOf(current) !== -1 ? current : cfg.drives[0];
              smwcSyncRows();
            };
            window.smwcCalculate = function() {
              var cfg = SMWC[el('smwcSubclass').value];
              var drive = el('smwcDrive').value;
              if (cfg.drives.indexOf(drive) === -1) {
                drive = cfg.drives[0];
              }
              var disp = parseFloat(el('smwcDisp').value);
              if (isNaN(disp) || disp <= 0) {
                el('smwcResult').textContent = '—';
                return;
              }
              var effDisp = disp + (el('smwcFi').checked ? cfg.fiAdd : 0);
              var rate = cfg.perL[drive];
              if (cfg.solid && drive === 'RWD' && el('smwcSolid').checked) {
                rate -= 25;
              }
              var weight = cfg.base[drive] + rate * effDisp;
              if (weight > cfg.cap) {
                weight = cfg.cap;
              }
              if (cfg.tire && el('smwcTire').checked) {
                weight -= 200;
              }
              el('smwcResult').textContent = Math.round(weight) + ' lbs.';
            };
            smwcUpdateUI();
            smwcCalculate();
          })();
        </script>
        {{ end }}
      </div>
      </br>
      <button class="button yesButton" onclick="setState(['{{ toVarName $name}}{{ menuName $subchapter.Name }}', '{{ $shortname }}CarAnsweredIndex'], [true, {{ addOne $index }}]); hideItem('{{ toVarName $name}}{{ menuName $subchapter.Name }}'); evalSessionStorage('{{ $shortname }}Car'); window.scroll(0,0);">Yes</button>
      <button class="button noButton" onclick="setState(['{{ toVarName $name}}{{ menuName $subchapter.Name }}', '{{ $shortname }}CarAnsweredIndex'], [false, {{ addOne $index }}]); hideItem('{{ toVarName $name}}{{ menuName $subchapter.Name }}'); evalSessionStorage('{{ $shortname }}Car'); window.scroll(0,0);">No</button>
    </div>
{{ end }}


    <div id="eligible" class="center eligible sansserif">
      <h1>
        Your car is eligible for Street Modified class!
        </br>
      </h1>
      <div id="smSubclasses" class="subclasses">
        <h2 id="smSubclass" class="subclass">Street Modified Subclass:</h2>
      </div>
      <div id="possibleClasses" class="possibleClasses">
        <h2 id="specificClass" class="specificClass">Possible Classes:</h2>
      </div>
    </div>

    <div id="notEligible" class="center notEligible sansserif">
      <h1>
        Your car is NOT eligible for Street Modified class.
      </h1>
      <div class="notEligibleExplanation">
        <h2>
          You answered "No" to the following questions, which resulted in your ineligibility:
        </h2>
        <p id="ineligibilityQuestions"></p>
      </div>
    </div>
  </body>
</html>
